[Unit]
Description=Run frp-report 3x daily (09:00, 15:00, 21:00 local time)

[Timer]
# 3 fires per day — adjust hours to taste
OnCalendar=*-*-* 09:00:00
OnCalendar=*-*-* 15:00:00
OnCalendar=*-*-* 21:00:00
# Run on boot if we missed a scheduled fire while powered off
Persistent=true
# Small random jitter so parallel boxes don't all hit Telegram at once
RandomizedDelaySec=60
Unit=frp-report.service

[Install]
WantedBy=timers.target
