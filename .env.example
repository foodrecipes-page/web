# ===== AI providers (all free tiers) =====
# Sign up: https://console.groq.com
GROQ_API_KEY=

# Sign up: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Sign up: https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Sign up: https://openrouter.ai
OPENROUTER_API_KEY=

# ===== GitHub shards =====
# Fine-grained PAT with `contents:write` on recipes-a..recipes-z repos
GITHUB_TOKEN=
GITHUB_OWNER=your-github-username

# ===== Upstash (free tier) =====
# Sign up: https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== Cloudflare Turnstile (free) =====
# Sign up: https://dash.cloudflare.com → Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ===== Site =====
NEXT_PUBLIC_SITE_URL=https://foodrecipes.page
